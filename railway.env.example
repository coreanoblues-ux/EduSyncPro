# =====================================================
# EduSyncPro — Railway 환경변수 설정 목록
# =====================================================
# 사용법: Railway 대시보드 → Variables → RAW Editor에 붙여넣기
# 주의: 실제 값으로 교체 후 사용 (이 파일은 절대 커밋하지 말 것)
# =====================================================

# [필수] NeonDB / Railway PostgreSQL 연결 문자열
# Railway PostgreSQL: 대시보드 → Postgres 서비스 → Variables → DATABASE_URL
# NeonDB: neon.tech 대시보드 → Connection string
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# [필수] JWT 서명 키 (32자 이상 랜덤 문자열 권장)
# 생성법: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=여기에_32자_이상의_랜덤_시크릿_키_입력

# [필수] 시스템 관리자(superadmin) 로그인 비밀번호
# 이 값이 없으면 admin 로그인이 비활성화됩니다 (앱은 정상 작동)
# 생성법: 12자 이상의 복잡한 비밀번호 권장
ADMIN_PASSWORD=여기에_관리자_비밀번호_입력

# [필수] 프로덕션 환경 명시
NODE_ENV=production

# [자동 제공 — 입력 불필요]
# PORT → Railway가 자동으로 주입
