# =====================================================
# EduSyncPro — Railway 환경변수 설정 목록
# =====================================================
# 사용법: Railway 대시보드 → Variables → RAW Editor에 붙여넣기
# 주의: 실제 값으로 교체 후 사용 (이 파일은 절대 커밋하지 말 것)
# =====================================================

# [필수] NeonDB 연결 문자열
# Replit 대시보드 → Secrets → DATABASE_URL 값 복사
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# [필수] JWT 서명 키 (32자 이상 랜덤 문자열 권장)
# 생성법: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=여기에_32자_이상의_랜덤_시크릿_키_입력

# [필수] 프로덕션 환경 명시
NODE_ENV=production

# [자동 제공 — 입력 불필요]
# PORT → Railway가 자동으로 주입
